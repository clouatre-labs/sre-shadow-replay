+def _build_seq_expression(
+    byte_width: int, signed: bool, unsigned_tmpl: exp.Expression, signed_tmpl: exp.Expression
+) -> exp.Expression:
+    """Build a SEQ expansion expression from templates.
+
+    Args:
+        byte_width: 1, 2, 4, or 8 bytes
+        signed: True when the SEQ signed parameter is 1
+        unsigned_tmpl: placeholder template for unsigned expansion
+        signed_tmpl: placeholder template for signed expansion
+
+    Returns:
+        Expanded expression with :max_val and :half substituted
+    """
+    bits = byte_width * 8
+    max_val = exp.Literal.number(2**bits)
+    if signed:
+        half = exp.Literal.number(2 ** (bits - 1))
+        return exp.replace_placeholders(signed_tmpl.copy(), max_val=max_val, half=half)
+    return exp.replace_placeholders(unsigned_tmpl.copy(), max_val=max_val)
+
+
+def _seq_to_range_in_generator(select: exp.Select) -> exp.Select:
+    """Preprocess transform: replace SEQ functions with the ``range`` column.
+
+    When a ``SELECT`` draws from ``TABLE(GENERATOR(ROWCOUNT => N))``, the
+    Snowflake ``SEQ*`` functions can be replaced with a reference to the
+    ``range`` column produced by DuckDB's ``RANGE(N)``.  This avoids the
+    nested window function that the default ``ROW_NUMBER()`` expansion would
+    otherwise produce, which DuckDB rejects with a parser error.
+    """
+    from_ = select.args.get("from_")
+    if not from_ or from_.find(exp.Generator) is None:
+        return select
+
+    unsigned_tmpl = exp.maybe_parse(f"{_SEQ_BASE_RANGE} % :max_val")
+    signed_tmpl = exp.maybe_parse(
+        f"(CASE WHEN {_SEQ_BASE_RANGE} % :max_val >= :half "
+        f"THEN {_SEQ_BASE_RANGE} % :max_val - :max_val "
+        f"ELSE {_SEQ_BASE_RANGE} % :max_val END)"
+    )
+    byte_map = {exp.Seq1: 1, exp.Seq2: 2, exp.Seq4: 4, exp.Seq8: 8}
+    for node in list(select.find_all(*byte_map.keys())):
+        replacement = _build_seq_expression(
+            byte_map[type(node)],
+            signed=(node.name == "1"),
+            unsigned_tmpl=unsigned_tmpl,
+            signed_tmpl=signed_tmpl,
+        )
+        node.replace(replacement)
+    return select
+
