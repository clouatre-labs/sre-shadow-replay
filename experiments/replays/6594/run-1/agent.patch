diff --git a/sqlglot/dialects/duckdb.py b/sqlglot/dialects/duckdb.py
index 85a01ed7e..99d843b66 100644
--- a/sqlglot/dialects/duckdb.py
+++ b/sqlglot/dialects/duckdb.py
@@ -91,43 +91,60 @@ MAX_BIT_POSITION = exp.Literal.number(32768)
 
 def _to_boolean_sql(self: DuckDB.Generator, expression: exp.ToBoolean) -> str:
     """
-    Transpile TO_BOOLEAN function from Snowflake to DuckDB equivalent.
+    Transpile TO_BOOLEAN / TRY_TO_BOOLEAN from Snowflake to DuckDB.
 
-    DuckDB's CAST to BOOLEAN supports most of Snowflake's TO_BOOLEAN strings except 'on'/'off'.
-    We need to handle the 'on'/'off' cases explicitly, plus NaN/INF error cases.
+    DuckDB's CAST to BOOLEAN supports most of Snowflake's valid input strings except
+    'on' / 'off', which we handle explicitly.
 
-    In Snowflake, NaN and INF values cause errors. We use DuckDB's native ERROR()
-    function to replicate this behavior with a clear error message.
+    For TO_BOOLEAN (safe=False):
+    - NaN / INF inputs raise an error, matching Snowflake's behavior.
+    - The fallback uses CAST, which raises on invalid strings.
+
+    For TRY_TO_BOOLEAN (safe=True):
+    - NaN / INF inputs return NULL instead of raising.
+    - The fallback uses TRY_CAST, which returns NULL for invalid strings.
+
+    NULL input: Snowflake's TRY_TO_BOOLEAN raises on NULL (undocumented behavior).
+    We intentionally do not replicate this because the error is undocumented, the
+    TRY_ prefix implies a null-safe contract, and silently returning NULL is the
+    more useful behavior for migrations.
     """
     arg = expression.this
+    safe = expression.args.get("safe")
 
     cast_to_real = exp.func("TRY_CAST", arg, exp.DataType.build("REAL"))
 
-    # Check for NaN and INF values
+    # NaN and INF are invalid for both variants; TRY_ returns NULL, non-TRY raises.
     nan_inf_check = exp.Or(
         this=exp.func("ISNAN", cast_to_real), expression=exp.func("ISINF", cast_to_real)
     )
+    nan_inf_result = (
+        exp.null()
+        if safe
+        else exp.func(
+            "ERROR",
+            exp.Literal.string("TO_BOOLEAN: Non-numeric values NaN and INF are not supported"),
+        )
+    )
+
+    fallback = (
+        exp.func("TRY_CAST", arg, exp.DataType.build("BOOLEAN"))
+        if safe
+        else exp.cast(arg, exp.DataType.Type.BOOLEAN)
+    )
 
     case_expr = (
         exp.case()
-        .when(
-            nan_inf_check,
-            exp.func(
-                "ERROR",
-                exp.Literal.string("TO_BOOLEAN: Non-numeric values NaN and INF are not supported"),
-            ),
-        )
-        # Handle 'on' -> TRUE (case insensitive) - only for string literals
+        .when(nan_inf_check, nan_inf_result)
         .when(
             exp.Upper(this=exp.cast(arg, exp.DataType.Type.VARCHAR)).eq(exp.Literal.string("ON")),
             exp.true(),
         )
-        # Handle 'off' -> FALSE (case insensitive) - only for string literals
         .when(
             exp.Upper(this=exp.cast(arg, exp.DataType.Type.VARCHAR)).eq(exp.Literal.string("OFF")),
             exp.false(),
         )
-        .else_(exp.cast(arg, exp.DataType.Type.BOOLEAN))
+        .else_(fallback)
     )
 
     return self.sql(case_expr)
