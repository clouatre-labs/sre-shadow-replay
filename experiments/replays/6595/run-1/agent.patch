 # BigQuery -> DuckDB conversion for the DATE function
 def _date_sql(self: DuckDB.Generator, expression: exp.Date) -> str:
-    result = f"CAST({self.sql(expression, 'this')} AS DATE)"
-    zone = self.sql(expression, "zone")
+    zone = expression.args.get("zone")
 
     if zone:
-        date_str = self.func("STRFTIME", result, "'%d/%m/%Y'")
-        date_str = f"{date_str} || ' ' || {zone}"
-
-        # This will create a TIMESTAMP with time zone information
-        result = self.func("STRPTIME", date_str, "'%d/%m/%Y %Z'")
-
-    return result
+        # BigQuery's DATE(timestamp_expr, time_zone) returns the date as seen in that timezone.
+        # DuckDB equivalent: CAST(CAST(this AS TIMESTAMP) AT TIME ZONE 'UTC' AT TIME ZONE zone AS DATE)
+        # The inner CAST AS TIMESTAMP strips any tz offset and yields the UTC wall-clock time,
+        # then the double AT TIME ZONE idiom re-interprets it as UTC and converts to the target tz.
+        ts = exp.cast(expression.this, exp.DataType.Type.TIMESTAMP)
+        at_utc = exp.AtTimeZone(this=ts, zone=exp.Literal.string("UTC"))
+        at_zone = exp.AtTimeZone(this=at_utc, zone=zone)
+        return self.sql(exp.cast(at_zone, exp.DataType.Type.DATE))
+
+    return f"CAST({self.sql(expression, 'this')} AS DATE)"
 
 
